vector<char> hillClimb(const QuadgramScorer& scorer, const string& ciphertext) {
  // TODO: student
  // function will do the single hill-climb iteration to create a better sub key

  // will start with a random key
  vector<char> bestKey = genRandomSubstCipher();
  string bestDecrypted = applySubstCipher(bestKey, ciphertext);
  double bestScore = scoreString(scorer, bestDecrypted);

  int trialsSinceLastImprovement = 0;

  // will keep trying until 1000 swaps without improvement
  while (trialsSinceLastImprovement < 1000) {
    // will make a copy of the current key
    vector<char> newKey = bestKey;

    // will pick two different random indices to swap
    int i = Random::randInt(25);
    int j = Random::randInt(25);
    while (j == i) {
      j = Random::randInt(25);
    }

    // will swap the letters manually
    char temp = newKey[i];
    newKey[i] = newKey[j];
    newKey[j] = temp;

    // will apply all the new key and calculate the score
    string newDecryption = applySubstCipher(newKey, ciphertext);
    double newScore = scoreString(scorer, newDecryption);

    // if statement for keeping the new key if its better
    if (newScore > bestScore) {
      bestKey = newKey;
      bestScore = newScore;
      // will reset the counter
      trialsSinceLastImprovement = 0;
    } else {
      trialsSinceLastImprovement++;
    }
  }
  return bestKey;
}

vector<char> decryptSubstCipher(const QuadgramScorer& scorer,
                                const string& ciphertext) {
  // TODO: student
  // will do run the hill climbing 25 times and return the best key

  vector<char> bestKey;
  // a very negative number for allowing first improvement
  double bestScore = -1e100;

  // will run hill climb 25 times
  for (int run = 0; run < 25; run++) {
    // will start with a random key
    vector<char> candidateKey = hillClimb(scorer, ciphertext);
    string decryptedText = applySubstCipher(candidateKey, ciphertext);
    double candidateScore = scoreString(scorer, decryptedText);

    if (candidateScore > bestScore) {
      bestScore = candidateScore;
      bestKey = candidateKey;
    }
  }

  return bestKey;
}

