// helper function for loading the dictionary into a vector
vector<string> loadTheDict(const string& filename) {
  // creating a vector so that I can change the size
  vector<string> dict;
  // input file stream variable
  ifstream file(filename);
  // variable for converting the word to uppercase
  string word;

  // incase if program cannot open the file
  if (!file) {
    cout << "Error: could not open dictionary file." << endl;
  }

  // will read each word in the file and store it in vector
  while (getline(file, word)) {
    // will convert the words to uppercase
    for (int i = 0; i < word.size(); i++) {
      word[i] = toupper(word[i]);
    }
    dict.push_back(word);
  }

  return dict;
}

