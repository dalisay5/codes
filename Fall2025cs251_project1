string applySubstCipher(const vector<char>& cipher, const string& s) {
  // TODO: student
  // will convert a char vector and string to uppercase. Others types will be
  // kept same

  // empty string
  string result = "";

  for (char ch : s) {
    if (isalpha(ch)) {
      // will convert the letter to uppercase
      char upper = toupper(ch);
      // fill find the position in the alphabet
      int index = upper - 'A';
      result.push_back(cipher[index]);
    } else {
      // will keep spaces, punctuation, etc
      result.push_back(ch);
    }
  }

  // outputs result
  return result;
}
