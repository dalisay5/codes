  // TODO: student
  // will try all the caesar shifts and will print the decrpytions

  cout << "Enter the text to decrypt:";
  string cipherTxt;
  getline(cin, cipherTxt);

  // will split the ciphertext into words
  vector<string> words = splitBySpaces(cipherTxt);

