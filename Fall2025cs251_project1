char rot(char c, int amount) {
  // TODO: student
  // rotates a single char by the 'amount' positions in alphabet

  // step 1, will find the index of c in alphabet
  int index = ALPHABET.find(c);

  // step 2, will add the rotation amount and wrap it back(0-25)
  int newIndex = (index + amount) % 26;

  // step 3, will return the new character
  return ALPHABET[newIndex];
}

string rot(const string& line, int amount) {
  // TODO: student
  // will rotate all characters in a string by "amount" positions

  // will start with an empty string
  string result = "";

  // step 1, will go through each character in the input line
  for (size_t i = 0; i < line.length(); i++) {
    char character = line[i];

    // step 1.1, will check for letters
    if (isalpha(character)) {
      // will convert to uppercase
      char upperC = toupper(character);

      // will rotate string by using single character rot function
      char rotated = rot(upperC, amount);

      // will add to result
      result += rotated;
    }
    // step 1.2, checks and keeps spaces
    else if (isspace(character)) {
      result += character;
    }
  }

  // will return the result
  return result;
}

