  // will open the input file
  ifstream inFile(inputFileName);
  if (!inFile.is_open()) {
    cout << "Failed to open output file." << endl;
    return;
  }

  // will read the entire file into a single string
  string ciphertxt;
  string line;
  while (getline(inFile, line)) {
    // will keep the new lines
    ciphertxt += line + '\n';
  }
  inFile.close();

  // will clean the text by converting to uppercase and keeping others
  string cleanedtxt = "";
  for (char ch : ciphertxt) {
    if (isalpha(ch)) {
      cleanedtxt.push_back(toupper(ch));
    } else {
      cleanedtxt.push_back(ch);
    }
  }

  // will decrypt it by using hill climbing
  vector<char> bestKey = decryptSubstCipher(scorer, cleanedtxt);
  string decryptedText = applySubstCipher(bestKey, cleanedtxt);

  // will use the decrypted text to output the file
  ofstream outFile(outputFileName);
  if (!outFile.is_open()) {
    cout << "Failed to open output file." << endl;
    return;
  }

  // will write all at once and keep the new Lines
  outFile << decryptedText;
  outFile.close();

  cout << "Decryption complete. output written to " << outputFileName << endl;
}

