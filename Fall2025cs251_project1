void rot(vector<string>& strings, int amount) {
  // TODO: student
  // will rotate each wrod in the vector by the given amount in function call

  for (string& s : strings) {
    for (char& c : s) {
      if (isalpha(c)) {
        // will find index of the character in ALPHABET global variable
        int index = ALPHABET.find(toupper(c));
        // string::pos, which is just a very large number(covered in class)
        if (index != string::npos) {
          int newIndex = (index + amount) % 26;
          c = ALPHABET[newIndex];
        }
      }
    }
  }
}

string clean(const string& s) {
  // TODO: student
  // will "clean" string, keeps only letters and converts them to uppercase

  // empty string for for loop
  string result = "";
  for (int i = 0; i < s.size(); i++) {
    if (isalpha(s[i])) {
      result += toupper(s[i]);
    }
  }

  return result;
}

vector<string> splitBySpaces(const string& s) {
  // TODO: student
  // will split the string into words by spaces, no punctuations

  vector<string> words;
  istringstream iss(s);
  string word;

  while (iss >> word) {
    words.push_back(clean(word));
  }
  return words;
}

string joinWithSpaces(const vector<string>& words) {
  // TODO: student
  // will combine vector of words back to one string with spaces

  string result;

  for (size_t i = 0; i < words.size(); i++) {
    result += words[i];
    if (i + 1 < words.size()) {
      result += " ";
    }
  }
  return result;
}

int numWordsIn(const vector<string>& words, const vector<string>& dict) {
  // TODO: student
  // will count the amount of words that are in the dictionary

  // will avoid dividle-by-zero
  if (dict.size() == 0) {
    // means this program will continue
    return 0;
  }

  // counter
  int count = 0;

  for (int i = 0; i < words.size(); i++) {
    for (int j = 0; j < dict.size(); j++) {
      if (words[i] == dict[j]) {
        count++;
        break;
      }
    }
  }
  return count;
}

