double scoreString(const QuadgramScorer& scorer, const string& s) {
  // TODO: student
  // will remove non-letter chars, converts to uppercase, and sums the quadgram
  string cleaned = "";

  for (char ch : s) {
    if (isalpha(ch)) {
      cleaned.push_back(toupper(ch));
    }
  }

  double totalScore = 0.0;
  for (size_t i = 0; i + 3 < cleaned.size(); i++) {
    string quadgram = cleaned.substr(i, 4);
    totalScore += scorer.getScore(quadgram);
  }

  return totalScore;
}

