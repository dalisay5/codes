      //will be for the new ROW
      Rows= new ROW[NumRows];

      //will loop through the NumRows using size_t for it to store any big num
      for(size_t row=0; row<NumRows; row++)
      {
        //will set the NumCols to other Numscols
        Rows[row].NumCols = other.Rows[row].NumCols;
        //will set the Cols to new T
        Rows[row].Cols =new T[Rows[row].NumCols];

        //wil then loop through the NumCols of rows inside Rows
        for(size_t c=0; c<Rows[row].NumCols; c++)
        {
            //will set the c insdie cols inside row of Rows to other
            Rows[row].Cols[c] = other.Rows[row].Cols[c];
        }
      }

    //will then return *this at the end finally
    return *this;  // TODO: update this, it is only here so code compiles.
      
  }

  //
  // numrows
  //
  // Returns the # of rows in the Grid.  
  // The indices for these rows are 0..numrows-1.
  //

  //will just return how many rows the grid has 
  size_t numrows() const {
      
    //-------------------------------------------------
    // TODO:  Write this function.
    //-------------------------------------------------
        
    //wil then return the NumRows
    return NumRows;  // TODO:  update this, it is only here so code compiles.
  }
  

  //
  // numcols
  //
  // Returns the # of columns in row r.  
  // The indices for these columns are 0..numcols-1.  
  // For now, each row has the same number of columns.
  //

  //will return amount of columns row r has, and where all rows have the same num of columns 
  size_t numcols(size_t r) const {
      
      //-------------------------------------------------
      // TODO:  Write this function.
      //-------------------------------------------------
      
        //will be if the rows are null and numrows is 0
        if(Rows==nullptr || NumRows==0)
        {
            //will return 0
            return 0;
        }
        //will check if r is greater or equal to NumRows
        if(r>= NumRows)
        {
            //will return 0 to continue
            return 0;
        }

      //will be for return the NumCols of Rows element
      return Rows[r].NumCols;  // TODO: update this, it is only here so code compiles.

