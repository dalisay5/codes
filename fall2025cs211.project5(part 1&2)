        {
            //will check if the east current is nullptr
            if(theCurr->east== nullptr)
            {
                //will then return false if so
                return false;
            }
            //will set the current to east if the statement above is not true
            theCurr= theCurr->east;
        }

        //will check if the aMove is W for west lastly
        else if(aMove == 'W')
        {
            //will check if the west of current is to null pointer
            if(theCurr->west ==nullptr)
            {
                //will return false f above statement is true 
                return false;
            }
            //will lastly set the current to west
            theCurr =theCurr->west;
        }

        //will be for if the statements if all false and for anything else
        else
        {
            //will lastly be for if invalid characters inside aMove are  false, will return false 
            return false;
        }

        //will be for colelcting the item elements if it lands on them
        //will check if the whatshere is spellbook
        if(theCurr->whatsHere== "Spellbook")
        {
            //will set the spell book to true
            theHasSpellbook =true;
        }
        //will check if the whatshere is equal to potion
        if(theCurr->whatsHere== "Potion")
        {
