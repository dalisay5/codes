      //-------------------------------------------------
      // TODO:  Write this function.
      //-------------------------------------------------
      
    
      //will store the total using size_t so it can hold any big num
      size_t theTotal=0;


      //will check if the NumRows is 0 or if NumRows is 0
      if(Rows== nullptr || NumRows==0)
      {
        //will retrun 0 and continue the program
