        //will check if the whatshere is equal to wand and set that want variable to true
        if(theCurr->whatsHere == "Wand")
        {
            //finally will set the wand to true
            theHasWand= true;
        }
    }




    //will lastly be return only if program has all 3 items like spellbook, potion and wand, and to true
    return (theHasSpellbook &&theHasPotion && theHasWand);
    
}





