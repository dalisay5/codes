    //will check if the Rows is not null pointer
    if(Rows !=nullptr)
    {
        //will the loop through NumRows using size_t for any big number
        for(size_t row=0; row<NumRows; row=row+1)
        {
            //will then delete that element for column
            delete[] Rows[row].Cols;
        }

        //will delete that rows as well 
        delete[] Rows;
    }
  }


  //
  // copy constructor:
  //
  // Called automatically to construct a Grid that contains a
  // copy of an existing Grid.  Example: this occurs when passing
  // Grid as a parameter by value
  //
  //   void somefunction(Grid<int> G2)  <--- G2 is a copy:
  //   { ... }
  //

  //this will basically make new grid that is copy of another, all rows/columns are rebuilt, and basically be "deep copy"
  Grid(const Grid<T>& other) {
      
      //-------------------------------------------------
      // TODO:  Write this copy constructor.
      //-------------------------------------------------

    //will check if other grid is empty
    if(other.Rows==nullptr || other.NumRows==0)
    {
        //will set the NumRows to 0
        NumRows = 0;
        //will set the rows
        Rows= nullptr;
        //will then return finally
        return;
    }


    //will set the NumRows to the NumRows other
    NumRows =other.NumRows;
    //will then create new ROW of Rows
    Rows= new ROW[NumRows];

    //will then loop through the numrows using the size_t to store any big num
    for(size_t row=0; row<NumRows; row++)
    {
        //will set the row element of rows to other
        Rows[row].NumCols =other.Rows[row].NumCols;
        //will set the cols of rows to new T
        Rows[row].Cols = new T[Rows[row].NumCols];

        //will then loop through the Numcols of the r element of Rows
        for(size_t col=0; col<Rows[row].NumCols; col++)
        {
            //will set the Cols of rows to other.rows.cols
            Rows[row].Cols[col] =other.Rows[row].Cols[col];
        }
    }
  }
    
  //
  // copy operator=
  //
  // Called when one Grid is assigned into another, i.e. this = other;
  //

  //will let program write grid1=grid2, delete old grid, copies all rows/columns from other grid(deep copy again)
  Grid& operator=(const Grid& other) {
    //   Grid<T> temp;
      
      //-------------------------------------------------
      // TODO:  Write this copy operator.
      //-------------------------------------------------

      //wll check if the this is equal to the address of other
      if(this== &other)
      {
        //will return this 
        return *this;
      }

      //will then free the memory to avoid leaks
      //will check if Rows is not nullptr
      if(Rows!=nullptr)
      {
        for(size_t r=0; r<NumRows; r=r+1)
        {
            //will delete the Cols of Rows
