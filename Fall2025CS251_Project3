  LinkedList<int> llist;
  // will push back at [1]
  llist.push_back(1);
  // will push back at [2]
  llist.push_back(2);
  // will push to front
  llist.pop_front();
  // will check if equal the llist size
  EXPECT_EQ(llist.size(), 1);
  // will check if equal the llist at [0]
  EXPECT_EQ(llist.at(0), 2);

