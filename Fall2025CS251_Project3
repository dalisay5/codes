TEST(CircVectorCore, PopBackNoWrapBugCaught) {
  CircVector<int> v(3);

  // Fill vector completely
  v.push_back(1);  // index 0
  v.push_back(2);  // index 1
  v.push_back(3);  // index 2

  // Shift front forward to force wrap-around
  v.pop_front();   // removes 1, front_idx = 1
  v.pop_front();   // removes 2, front_idx = 2
  v.push_back(4);  // wraps around to index 0

  // Now the underlying array is [4,_,3] with front_idx = 2
  // pop_back should remove 4 (wrapped index)
  EXPECT_EQ(v.pop_back(), 4);
  EXPECT_EQ(v.size(), 1);
  EXPECT_EQ(v.at(0), 3);

  // pop_back again removes 3
  EXPECT_EQ(v.pop_back(), 3);
  EXPECT_EQ(v.size(), 0);
  EXPECT_TRUE(v.empty());
}

