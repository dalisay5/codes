#pragma once

#include <iostream>
#include <sstream>
#include <stdexcept>
#include <string>

using namespace std;

template <typename T>
class LinkedList {
 private:
  class Node {
   public:
    T data;
    Node *next;

    Node(T data) {
      this->data = data;
      this->next = nullptr;
    }

    Node(T data, Node *next) {
      this->data = data;
      this->next = next;
    }
  };

  size_t list_size;
  Node *list_front;

 public:
  /**
   * Default constructor. Creates an empty `LinkedList`.
   */
  LinkedList() {
    // will set the front to null
    list_front = nullptr;
    // will set the size to 0;
    list_size = 0;
  }

  /**
   * Returns whether the `LinkedList` is empty (i.e. whether its
   * size is 0).
   */
  bool empty() const {
    // will return the list size to 0
    return list_size == 0;
  }

  /**
   * Returns the number of elements in the `LinkedList`.
   */
  size_t size() const {
    // will return the list size
    return list_size;
  }

  /**
   * Adds the given `T` to the front of the `LinkedList`.
   */
  void push_front(T data) {
    // will create a new node using the new operator
    Node *theNewNode = new Node(data, list_front);
    // will set the front to the new Node
    list_front = theNewNode;
    // will increment the size
    list_size++;
  }

  /**
   * Adds the given `T` to the back of the `LinkedList`.
   */
  void push_back(T data) {
    // will create the new node using the new operator
    Node *theNewNode = new Node(data);
    // checks if list is empty
    if (empty()) {
      list_front = theNewNode;
    } else {
      // will create new node to current
      Node *current = list_front;
      // will check if the next is null
      while (current->next != nullptr) {
        current = current->next;
      }
      // will set next to the new mode
      current->next = theNewNode;
    }
    // will increment the size
    list_size++;
  }

  /**
   * Removes the element at the front of the `LinkedList`.
   *
   * If the `LinkedList` is empty, throws a `runtime_error`.
   */
  T pop_front() {
    if (empty())
      throw std::runtime_error("Cannot pop_front from empty LinkedList");
    Node *temp = list_front;
    T value = temp->data;
    list_front = list_front->next;
    delete temp;
    list_size--;
    return value;
  }

  /**
   * Removes the element at the back of the `LinkedList`.
   *
   * If the `LinkedList` is empty, throws a `runtime_error`.
   */
  T pop_back() {
    if (empty())
      throw std::runtime_error("Cannot pop_back from empty LinkedList");

    if (list_front->next == nullptr) {
      T value = list_front->data;
      delete list_front;
      list_front = nullptr;
      list_size = 0;
      return value;
    }

    Node *current = list_front;
    while (current->next->next != nullptr) {
      current = current->next;
    }

    T value = current->next->data;
    delete current->next;
    current->next = nullptr;
    list_size--;
    return value;
  }

  /**
   * Empties the `LinkedList`, releasing all allocated memory, and resetting
   * member variables appropriately.
   */
  void clear() {
    // will create a new node called current
    Node *current = list_front;
    while (current != nullptr) {
      Node *theNextNode = current->next;
      delete current;
      current = theNextNode;
    }
    list_front = nullptr;
    list_size = 0;
  }

  /**
   * Destructor. Clears all allocated memory.
   */
  ~LinkedList() {
    // will call the clear function
    clear();
  }

  /**
   * Returns the element at the given index in the `LinkedList`.
   *
   * If the index is invalid, throws `out_of_range`.
   */
  T &at(size_t index) const {
    if (index >= list_size) {
      throw std::out_of_range("index out of bounds");
    }
    Node *current = list_front;
    for (size_t i = 0; i < index; i++) current = current->next;
    return current->data;
  }

  /**
   * Copy constructor. Creates a deep copy of the given `LinkedList`.
   *
   * Must run in O(N) time.
   */
  LinkedList(const LinkedList &other) {
    list_front = nullptr;
    list_size = 0;
    if (other.list_front == nullptr) return;

    // Copy first node
    list_front = new Node(other.list_front->data);
    Node *curr_new = list_front;
    Node *curr_old = other.list_front->next;
    list_size = 1;

    // Copy the rest in one pass
    while (curr_old != nullptr) {
      curr_new->next = new Node(curr_old->data);
      curr_new = curr_new->next;
      curr_old = curr_old->next;
      list_size++;
    }
  }

  /**
   * Assignment operator. Sets the current `LinkedList` to a deep copy of the
   * given `LinkedList`.
   *
   * Must run in O(N) time.
   */
  LinkedList &operator=(const LinkedList &other) {
    if (this == &other) return *this;  // self-assignment guard
    clear();

    if (other.list_front == nullptr) return *this;

    // Copy first node
    list_front = new Node(other.list_front->data);
    Node *curr_new = list_front;
    Node *curr_old = other.list_front->next;
    list_size = 1;

    // Copy the rest
    while (curr_old != nullptr) {
      curr_new->next = new Node(curr_old->data);
      curr_new = curr_new->next;
      curr_old = curr_old->next;
      list_size++;
    }

    return *this;
  }

  /**
   * Converts the `LinkedList` to a string. Formatted like `[0, 1, 2, 3, 4]`
   * (without the backticks -- hover the function name to see). Runs in O(N)
   * time.
   */
  string to_string() const {
    stringstream ss;
    ss << "[";
    Node *current = list_front;
    while (current != nullptr) {
      ss << current->data;
      if (current->next != nullptr) ss << ", ";
      current = current->next;
    }
    ss << "]";
    return ss.str();
  }

  /**
   * Searches the `LinkedList` for the first matching element, and returns its
   * index. If no match is found, returns "-1".
   */
  size_t find(const T &data) {
    Node *current = list_front;
    size_t index = 0;
    while (current != nullptr) {
      if (current->data == data) return index;
      current = current->next;
      index++;
    }
    return static_cast<size_t>(-1);
  }

  /**
   * Remove the element at the specified index in this list.
   *
   * If the index is invalid, throws `out_of_range`.
   */
  void remove_at(size_t index) {
    if (index >= list_size) throw std::out_of_range("index out of range");

    if (index == 0) {
      pop_front();
      return;
    }

    Node *prev = list_front;
    for (size_t i = 0; i < index - 1; i++) {
      prev = prev->next;
    }

    Node *target = prev->next;
    prev->next = target->next;
    delete target;
    list_size--;
  }

  /**
   * Inserts the given `T` as a new element in the `LinkedList` after
   * the given index. If the index is invalid, throws `out_of_range`.
   */
  void insert_after(size_t index, T data) {
    // Invalid index check
    if (index >= list_size) throw std::out_of_range("index out of range");

    Node *current = list_front;
    for (size_t i = 0; i < index; ++i) {
      current = current->next;
    }

    // Create a new node that points to current->next
    Node *newNode = new Node(data, current->next);
    current->next = newNode;
    list_size++;
  }

  /**
   * Remove every element that is currently in an
   * even-numbered position on the list.
   *
   * Must run in O(N).
   *
   * For example, if a list was `[3, 9, 7, 6, 8]`, remove_evens
   * would change the list to `[9, 6]`, since we remove the
   * values in positions 0, 2, and 4 (the even-numbered indices)
   * from the list.
   */
  void remove_evens() {
    // If list is empty, just return
    if (empty()) return;

    Node *current = list_front;
    Node *prev = nullptr;
    size_t index = 0;

    while (current != nullptr) {
      Node *nextNode = current->next;
      if (index % 2 == 0) {  // remove even index nodes
        if (prev == nullptr) {
          // removing front node
          list_front = nextNode;
        } else {
          prev->next = nextNode;
        }
        delete current;
        list_size--;
      } else {
        // keep odd index nodes
        prev = current;
      }
      current = nextNode;
      index++;
    }
  }

  /**
   * Returns a pointer to the node at the front of the `LinkedList`. For
   * autograder testing purposes only.
   */
  void *front() const {
    return this->list_front;
  }
};
