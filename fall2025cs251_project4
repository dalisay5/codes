template <typename KeyT, typename ValT>
class BSTMap {
 private:
  struct BSTNode {
    const KeyT key;  // This member should never change after initialization!
    ValT value;
    BSTNode* parent;
    BSTNode* left;
    BSTNode* right;

    // This is fancy constructor syntax
    // Don't worry too much about it -- it's just necesssary for the const
    // member.
    BSTNode(KeyT key, ValT value, BSTNode* parent)
        : key(key),
          value(value),
          parent(parent),
          left(nullptr),
          right(nullptr) {
    }
  };

  BSTNode* root;
  size_t sz;

  // Utility pointer for begin and next.
  BSTNode* curr;

  //&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&

  // TODO_STUDENT: add private helper function definitions here

  // will use Recursive insert helper
  bool insertHelperFunction(BSTNode*& node, BSTNode* parent, KeyT key,
                            ValT value) {
    // will check if node is valid or not
    if (!node) {
      // will create the BSTNode type using the constructor above
      node = new BSTNode(key, value, parent);
      return true;
    }
    // will see if key is less than key
    if (key < node->key) {
      return insertHelperFunction(node->left, node, key, value);
    }
    // will see if key is greater
    if (key > node->key) {
      return insertHelperFunction(node->right, node, key, value);
    }
    // will return key that already exists
    return false;
  }

  // will be for Recursive contains helper with BSTNode* and keey
  bool containsHelperFunction(BSTNode* node, const KeyT& key) const {
    // will see is the node inside argument is even valid or not
    if (!node) {
      return false;
    }
    // will check is key in argument is equal to the key of node
    if (key == node->key) {
      return true;
    }
    // will check if key is less than key of node
    if (key < node->key) {
      return containsHelperFunction(node->left, key);
    }
    // will use right side in argument
    return containsHelperFunction(node->right, key);
  }

  // will delete all nodes using recursion
  void deleteAllHelperFunction(BSTNode* node) {
    // will check if node is invalid
    if (!node) {
      return;
    }
    // will use deleteAll function for left side
    deleteAllHelperFunction(node->left);
    // will use function for right side
    deleteAllHelperFunction(node->right);
    // will use delete operator to avoid leak
    delete node;
  }

  // will Recursive to_string helper (in-order) and ostringstream&
  void toStringHelperFunction(BSTNode* node, ostringstream& inputString) const {
    if (!node) {
      return;
    }
    // will use recursion and use left side and the inputString
    toStringHelperFunction(node->left, inputString);
    inputString << node->key << ": " << node->value << endl;
    // will use recursion here too
    toStringHelperFunction(node->right, inputString);
  }

  // will be for Recursive at helper
  ValT& atHelperFunction(BSTNode* node, const KeyT& key) const {
    if (!node) {
      throw out_of_range("Key not found");
    }
    // will see if key is equal to key
    if (key == node->key) {
      return node->value;
    }
    // will see if key is less than key
    if (key < node->key) {
      return atHelperFunction(node->left, key);
    }
    // will return using right side and the key
    return atHelperFunction(node->right, key);
  }

  // will be helper for erase() with BSTNode pointer, key and removed value
  BSTNode* eraseHelperFunction(BSTNode* node, const KeyT& key,
                               ValT& removedVal) {
    // will throw out of range error if no key, this was used project 3
    if (!node) {
      throw out_of_range("Key is not found");
    }

    // will check key and left and right keys using recursively
    if (key < node->key) {
      node->left = eraseHelperFunction(node->left, key, removedVal);
      if (node->left) {
        node->left->parent = node;
      }
    } else if (key > node->key) {
      node->right = eraseHelperFunction(node->right, key, removedVal);
      if (node->right) {
        node->right->parent = node;
      }
    } else {
      removedVal = node->value;

      // will be for Case 1 with no children, and avoid leak
      if (!node->left && !node->right) {
        // will delete node
        delete node;
        return nullptr;
      }

      // will be for Case 2 where it is one child
      if (!node->left) {
        BSTNode* temp = node->right;
        temp->parent = node->parent;
        // will delete node to avoid leak
        delete node;
        return temp;
      }
      if (!node->right) {
        BSTNode* temp = node->left;
        temp->parent = node->parent;
        // will delete node to avoid leaks
        delete node;
        return temp;
      }

      // will Case 3, two children, finds successor left-most in right sub-tree
      BSTNode* succParent = node;
      BSTNode* nodeAfter = node->right;
      while (nodeAfter->left) {
        succParent = nodeAfter;
        nodeAfter = nodeAfter->left;
      }

      // will Remove the successor(succParent) from its parent
      if (succParent->left == nodeAfter) {
        succParent->left = nodeAfter->right;
        if (nodeAfter->right) {
          nodeAfter->right->parent = succParent;
        }
        // will be for anything else
      } else {
        succParent->right = nodeAfter->right;
        if (nodeAfter->right) {
          nodeAfter->right->parent = succParent;
        }
      }

      // will Replace node with successor (succ keeps its key)
      nodeAfter->left = node->left;
      if (nodeAfter->left) {
        nodeAfter->left->parent = nodeAfter;
      }
      // will set the successor(After) with right
      nodeAfter->right = node->right;
      if (nodeAfter->right) {
        nodeAfter->right->parent = nodeAfter;
      }
      // will set parent of succ equal to parent of node
      nodeAfter->parent = node->parent;

      // will delete the node to avoid leak
      delete node;
      return nodeAfter;
    }

    return node;
  }

  // will be for Recursive copy helper with use of BSTNode* pointer
  BSTNode* copyTreeHelperFunction(BSTNode* node, BSTNode* parent) {
    if (!node) {
      return nullptr;
    }
    // will give space for the pointer that will point left/right and no leak
    BSTNode* newNode = new BSTNode(node->key, node->value, parent);
    // will set left and right using the tree helper function
    newNode->left = copyTreeHelperFunction(node->left, newNode);
    newNode->right = copyTreeHelperFunction(node->right, newNode);
    return newNode;
  }

  //&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&
 public:
  /**
   * Creates an empty `BSTMap`. Runs in O(1).
   */
  BSTMap() {
    // TODO_STUDENT

    // will set root pointer to nullptr, which means the tree is empty
    root = nullptr;

    // will make the size of our map starts at 0, since it's empty.
    sz = 0;

    // will set curr pointer to nullptr to show its not currently active
    curr = nullptr;
  }

  /**
   * Checks if the `BSTMap` is empty. Runs in O(1).
   */
  bool empty() const {
    // TODO_STUDENT

    // will return sz as 0, sz stands for size
    return sz == 0;
  }

  /**
   * Returns the number of mappings in the `BSTMap`. Runs in O(1).
   */
  size_t size() const {
    // TODO_STUDENT

    // will return the variable sz which stands for size
    return sz;
  }

  /**
   * Adds the mapping `{key -> value}` to the `BSTMap`. If the key already
   * exists, does not update the mapping (like the C++ STL map).
   *
   * Uses the key to determine the location in the underlying BST. Creates
