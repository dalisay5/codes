  ValT& at(const KeyT& key) const {
    // TODO_STUDENT

    // will return using the helperfunction
    return atHelperFunction(root, key);
    // return this->root->value;
  }

  /**
   * Returns `true` if the key is present in the map, and false otherwise.
   *
   * Runs in O(H), where H is the height of the tree.
   */
  bool contains(const KeyT& key) const {
    // TODO_STUDENT
    // will return using the helper function that I created above
    return containsHelperFunction(root, key);
    // return false;
  }

  /**
   * Empties the `BSTMap`, freeing all memory it controls.
   *
   * Runs in O(N), where N is the number of mappings.
   */
  void clear() {
    // TODO_STUDENT

    // will delete using the helper function
    deleteAllHelperFunction(root);
    // will set the variables to nullptr/ 0
    root = nullptr;
    sz = 0;
    curr = nullptr;
  }

  /**
   * Destructor, cleans up the `BSTMap`.
   *
   * Runs in O(N), where N is the number of mappings.
   */
  ~BSTMap() {
    // TODO_STUDENT
    // will use the clear function
    clear();
  }

  /**
   * Converts the `BSTMap` to a string representation, with the values
   * in-order by key.
   *
   * Example:
   *
   * ```c++
   * BSTMap<string, int> names;
   * names.insert("Gwen", 10);
   * names.insert("Jen", 5);
   * names.insert("Ben", 10);
   * names.insert("Sven", 7);
   * ```
   *
   * Calling `names.to_string()` would return the following **multi-line**
   * string:
   *
   * ```text
   * Ben: 10
   * Gwen: 10
   * Jen: 5
   * Sven: 7
   * ```
   *
   * Runs in O(N), where N is the number of mappings.
   */
  string to_string() const {
    // TODO_STUDENT
    // will create ostring stream variable to get the string and hlper function
    ostringstream inputString;
    toStringHelperFunction(root, inputString);
    // return the string using str() function
    return inputString.str();
  }

  /**
   * Copy constructor.
   *
   * Copies the mappings from the provided `BSTMap`.
   * The internal tree structure must be copied exactly.
   *
   * Runs in O(N), where N is the number of mappings in `other`.
   */
  BSTMap(const BSTMap& other) {
    // TODO_STUDENT
    // wll inialize the member variables to null/ 0
    root = nullptr;
    sz = other.sz;
    curr = nullptr;

    // will use the tree copier helper function
    root = copyTreeHelperFunction(other.root, nullptr);
  }

  /**
   * Assignment operator; `operator=`.
   *
   * Clears this tree, and copies the mappings from the provided `BSTMap`.
   * The internal tree structure must be copied exactly.
   *
   * Runs in O(N + O), where N is the number of mappings in `this`, and O is
   * the number of mappings in `other`.
   */
  BSTMap& operator=(const BSTMap& other) {
    // TODO_STUDENT
    // will check if this is not equal to the other in argument
    if (this != &other) {
      // will clear
      clear();
      // will set size in member variable
      sz = other.sz;
      // will use the helper funciton to copy
      root = copyTreeHelperFunction(other.root, nullptr);
    }
    return *this;
  }

  // =========================================================================

  // task 2 is below////////////////////////////////////////////////

  /**
   * Locates the smallest key in the BSTMap, and removes and returns its
   * mapping. If the `BSTMap` is empty, throws a `runtime_error`.
   *
   * Creates no new nodes, and does not update the key or value of any
   * existing nodes.
   *
   * Runs in O(H), where H is the height of the tree.
   */
  pair<KeyT, ValT> remove_min() {
    // TODO_STUDENT
    // will check if root is equal to null and throw the error, used in proj 3
    if (root == nullptr) {
      throw runtime_error("Cannot remove_min from the empty BST tree");
    }

    // creates the class variables parent and node
    BSTNode* theParent = nullptr;
    BSTNode* node = root;

    // will find the leftmost node in smallest way
    while (node->left != nullptr) {
      theParent = node;
      node = node->left;
    }

    // will save the key and value to return later
    pair<KeyT, ValT> theResult(node->key, node->value);

    // will be for if the node is root
    if (theParent == nullptr) {
      // will be if it could be nullptr
      root = root->right;
      if (root != nullptr) {
        root->parent = nullptr;
      }
    } else {
      // will be for node->right may be nullptr
      theParent->left = node->right;
      if (node->right != nullptr) {
        node->right->parent = theParent;
      }
    }

    delete node;
    // will decrement the size
    sz = sz - 1;
    // will return theResult which is a map
    return theResult;
  }

  /**
   * Checks if the contents of `this` and `other` are equivalent.
   *
   * Two `BSTMap` objects are equivalent if they contain the same
   * mappings from key to value. To be equivalent, the two `BSTMap`
   * objects need not have the same internal tree structure.
   *
   *
   * Two different approaches could be used here.
   *
   * Approach #1:
   * Runs in worst-case O(N) time, using worst-case O(N) heap space,
   * where N is the maximum number of nodes in either of the `BSTMap`
   * objects. Since you cannot include other C++ classes, the extra
   * space in this approach would have to be used with arrays or
   * with `string` objects.
   *
   * Approach #2:
   * Runs in worst-case O(N*H) time, using worst-case O(1) space on
   * the heap, where N is the maximum number of nodes in either of
   * the `BSTMap` objects and H is the largest height between the two
   * `BSTMap` objects.
   *
   */
  bool operator==(const BSTMap& other) const {
    // TODO_STUDENT
    // will check if this is equal to the address of other
    if (this == &other) {
      return true;
    }
    // will check if the size member variable is not equal to other.size
    if (sz != other.sz) {
      return false;
    }

    // will use in-order (left,node,right), copies for begin() and next()
    BSTMap<KeyT, ValT> copyA = *this;
    BSTMap<KeyT, ValT> copyB = other;

    copyA.begin();
    copyB.begin();

    // will create variables from KeyT and ValT
    KeyT keyA;
    KeyT keyB;
    ValT valA;
    ValT valB;

    // will move through both the trees together
    // said in project manual we can use next()
    bool moreA = copyA.next(keyA, valA);
    bool moreB = copyB.next(keyB, valB);

    // will create codition while moreA and moreB are true
    while (moreA && moreB) {
      // will go if keyA!=keyB or if valA!=valB
      if (keyA != keyB || valA != valB) {
        return false;
      }

      // will set moreA and moreB using next()
      // said in project manual that we can use next()
      moreA = copyA.next(keyA, valA);
      moreB = copyB.next(keyB, valB);
    }

    // will make both end at the same time
    return moreA == moreB;
  }

  /**
   * Resets internal state for an iterative inorder traversal.
   *
   * See `next` for usage details. Modifies nothing except for `curr`.
   *
   * O(H), where H is the maximum height of the tree.
   */
  void begin() {
    // TODO_STUDENT
    curr = root;

    // will be for empty tree
    if (curr == nullptr) {
      return;
    }

    // willll go left until we reach the smallest node
    while (curr->left != nullptr) {
      curr = curr->left;
    }
  }

  /**
   * Uses the internal state to return the next in-order key and value
   * by reference, and advances the internal state. Returns `true` if the
   * reference parameters were set, and `false` otherwise.
   *
   * Example usage:
   *
   * ```c++
   * BSTMap<string, int> bst;
   * bst.begin();
   * string key;
   * int value;
   * while (bst.next(key, val)) {
   *   cout << key << ": " << val << endl;
   * }
   * ```
   *
   * Modifies nothing except for `curr`.
   *
   * Runs in worst-case O(H) where H is the height of the tree.
   */
  bool next(KeyT& key, ValT& val) {
    // TODO_STUDENT

    // will be for if the tree is empty or we are done will return false
    if (root == nullptr || curr == nullptr) {
      return false;
    }

    // will give the the current key and value
    key = curr->key;
    val = curr->value;

    // will be case 1,it goes to leftmost node if current has right child
    if (curr->right != nullptr) {
      // will create variable of BSTNode
      BSTNode* node = curr->right;
      // will go while left of node is not null
      while (node->left != nullptr) {
        node = node->left;
      }
      curr = node;
      return true;
    }

    // will be case 2, otherwise go up to first past node, from it left child
    BSTNode* successorAfter = nullptr;
    BSTNode* ancestorBefore = root;
    while (ancestorBefore != nullptr) {
      if (curr->key < ancestorBefore->key) {
        // will set the successor and ancestor
        successorAfter = ancestorBefore;
        ancestorBefore = ancestorBefore->left;
      } else if (curr->key > ancestorBefore->key) {
        ancestorBefore = ancestorBefore->right;
      } else {
        // will stop if anything else happens
        break;
      }
    }

    // will move to the next node, or nullptr if done
    curr = successorAfter;
    return true;
  }

  // =========================================================================

  /**
   * Removes the mapping for the given key from the `BSTMap`, and returns the
   * value.
   *
   * Throws `out_of_range` if the key is not present in the map. Creates no new
   * nodes, and does not update the key or value of any existing nodes.
   *
   * Runs in worst-case O(H) where H is the height of the tree.
   */
  ValT erase(const KeyT& key) {
    // TODO_STUDENT
    // will check if root is valid
    if (!root) {
      throw out_of_range("Key is not found");
    }
    // will creeate variable for the removed value
    ValT removedTheValue;
    // will use the erase helper function to erase
    root = eraseHelperFunction(root, key, removedTheValue);
    // will check if root is valid
    if (root) {
      root->parent = nullptr;
    }
    // will decrement size once per successful erase
    sz--;
    return removedTheValue;
  }

  // =========================================================================

  /**
   * Returns a pointer to the root node of the `BSTMap`. For autograder testing
