WordNode* findShortestWordLadder(   char** words, 
                                    bool* usedWord, 
                                    int numWords, 
                                    int wordSize, 
                                    char* startWord, 
                                    char* finalWord ) {
    //---------------------------------------------------------
    // TODO - write findShortestWordLadder()
    //---------------------------------------------------------
    
    //will make function find the shortest ladder(minimum word changes) between startWord and finalWord, each word differs by 1 char from previous

    //will create the first ladder with the starting word
    WordNode* theStrtingLadder = NULL;
    //will use the insertWordAtFront() function
    insertWordAtFront(&theStrtingLadder, startWord);

    //will then create the ladder list which will go by which ever goes first is the first to get output
    LadderNode* ladderList = NULL;
    //will use the insertLadderAtBack() function again
    insertLadderAtBack(&ladderList, theStrtingLadder);

    //will mark the start word as used in the dictionary
    int startingIndex = findWord(words, startWord, 0, numWords-1);
    //will check if starting index is greater or equal to 0
    if(startingIndex>=0)
    {
        //usedWord pointer is initialized in the main below()
        usedWord[startingIndex] = true;
    }

    //will use main Breadth-First search loop for level by level starting at starting point
    while(ladderList!=NULL)
    {
        //will get the first ladder in the list
        WordNode* currentLadder = popLadderFromFront(&ladderList);
        //will not need to dereference a null pointer
        if(currentLadder==NULL)
        {
            continue;
        }

        char* topWord = currentLadder->myWord;

        //will try all of the possible one letter changes to the topWord
        
        //will make max length wordSize+1
        char tempWord[wordSize+1];
        strcpy(tempWord, topWord);
        
        for(int i=0; i<wordSize; i++)
        {
            //will create variable for the original character
            char originalChar = tempWord[i];
            //will add a second for loop and go through the alphabet
            for(char ch='a'; ch<='z'; ch++)
            {
                if(ch==originalChar)
                {
                    //will skip the same letter
                    continue;
                }
                //will make the element at tempWord equal to the current ch of for loop
                tempWord[i] = ch;

                //will check if the word is in the dictionary
                int position = findWord(words, tempWord, 0, numWords-1);
                //will be condition where if position is greater or equal to 0 and !userWord[pos] where its not valid
                if(position>=0 && !usedWord[position])
                {
                    //will set the position in usedWord as true and valid
                    usedWord[position] = true;

                    //will copy the ladder to add the new word
                    WordNode* newLadder = copyLadder(currentLadder);
                    //will add the new word at the beginning
                    insertWordAtFront(&newLadder, words[position]);
                    //will add to the ladder list like a line
                    insertLadderAtBack(&ladderList, newLadder);

                    //will then exit if its found
                    if(strcmp(words[position], finalWord)==0)
                    {
                        //will use the freeladder() and freeladderList()
                        freeLadder(currentLadder);
                        freeLadderList(ladderList);
                        //will finally return the new ladder 
                        return newLadder;
                
                    }
                }
            }
            //will restore the original character that we displayed
            tempWord[i] = originalChar;
        }
        //will free the currentLadder after getting the ladder
        freeLadder(currentLadder);
    }
    //will finally return null is no ladder was found
    freeLadderList(ladderList);
    return NULL; //modify this line
}

