int findWord(char** words, char* aWord, int loInd, int hiInd) {
    //---------------------------------------------------------
    // TODO - write findWord()
    //---------------------------------------------------------

    //will do binary search aWord between low and high indices inclusive and return if found, -1 else

    //will create variable for the low and higher indices
    int low = loInd;
    int theHigh = hiInd;

    //will search through the highs and lows using binary search
    while(low<=theHigh)
    {
        //will create variable for the middle and comparison variables
        int mid = low + (theHigh-low)/2;
        int cmp = strcmp(aWord, words[mid]);

        //will return the middle if cmp is 0
        if(cmp==0)
        {
            return mid;
        }
        //will set high to mid-1 if cmp is less than 0
        if(cmp<0)
        {
            theHigh = mid-1;
        }
        //will set low to mid+1 if anything else
        else
        {
            //will set the low to mid+1
            low = mid+1;
        }
    }

    //i dont need to modify the line because the variables are set
    return -1; // modify this line
}

