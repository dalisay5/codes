WordNode* copyLadder(WordNode* ladder) {
    //---------------------------------------------------------
    // TODO - write copyLadder()
    //---------------------------------------------------------
    
    //will make a copy of the given ladder and return the new head
    if(ladder==NULL)
    {
        return NULL;
    }
    
    WordNode* newHead=NULL;
    WordNode* tail = NULL;

    //will loop through the nodes
    for(WordNode* theCurrent = ladder; theCurrent!=NULL; theCurrent=theCurrent->next)
    {
        WordNode* newNode = malloc(sizeof(WordNode));

        //will check if newNode is valid
        if(!newNode)
        {
            //will make program exit if newNode is not valid
            exit(1);
        }
        //will point to the same dictionary string
        newNode->myWord = theCurrent->myWord;
        newNode->next = NULL;

        if(newHead==NULL)
        {
            newHead = newNode;
        }
        else
        {
            tail->next = newNode;
        }
        tail = newNode;
    }

    //will return the new head at the start
    return newHead; //modify this line
}

void freeLadder(WordNode* ladder) {
    //---------------------------------------------------------
    // TODO - write freeLadder()
    //---------------------------------------------------------

    //will free all nodes in the ladder
    WordNode* freeNode;

    //will check while ladder is not NULL
    while(ladder!=NULL)
    {
        freeNode = ladder;
        ladder = ladder->next;

        //will free the free node itself and string
        free(freeNode);
    }
}

