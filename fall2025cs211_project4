void insertLadderAtBack(LadderNode** list, WordNode* newLadder) {
    //---------------------------------------------------------
    // TODO - write insertLadderAtBack()
    //---------------------------------------------------------

    //will add a new ladder which is in WordNode list, to the END of list

    //will allocate a new LadderNode pointer
    LadderNode* theNewNode = malloc(sizeof(LadderNode));
    //will check if new node is null
    if(theNewNode==NULL)
    {
        //will exit if the node is null
        exit(1);
    }

    //will store the ladder pointer
    theNewNode->topWord = newLadder;
    theNewNode->next = NULL;

    //will make new node the head if the list is empty, this is edge case #1
    if(*list==NULL)
    {
        *list = theNewNode;
        return;
    }

    //will findd the last node and add to the end if anything else
    LadderNode* theCurrent = *list;
    while(theCurrent->next != NULL)
    {
        theCurrent=theCurrent->next;
    }
    theCurrent->next = theNewNode;


}

WordNode* popLadderFromFront(LadderNode** list) {
    //---------------------------------------------------------
    // TODO - write popLadderFromFront()
    //---------------------------------------------------------
    
    //will remove the first ladder from the front of list and return the WordNode pointer of ladder
    
    //will handle an empty list case
    if(*list ==NULL)
    {
        return NULL;
    }

    //will save the ladder from the first node
    LadderNode* temporaryNode = *list;
    WordNode* ladder = temporaryNode->topWord;


    //will move the list head down one node
    *list = temporaryNode->next; //modify this line

    //will free the laddernode itself (not the ladder though)
    free(temporaryNode);

    //will return the ladder pointer finally
    return ladder; //modify this line
}

void freeLadderList(LadderNode* myList) {
    //---------------------------------------------------------
    // TODO - write freeLadderList()
    //---------------------------------------------------------

    //will free all the ladders and the list nodes

    //will go through all the ladders and free them
    
    //will create new ladderNode variable
    LadderNode* theCurrent = myList;

    //will check if current is null in while loop
    while(theCurrent != NULL)
    {
        //will set the temp node to the current node
        LadderNode* nodeToDelete = theCurrent;
        //will set the current to next one 
        theCurrent = theCurrent->next;
        //will use the freeladder function for the node to free later
        freeLadder(nodeToDelete->topWord);
        //will free to avoid leaks
        free(nodeToDelete);
    }

}

