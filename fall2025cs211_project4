int strCmpCnt(char* str1, char* str2) {
    //---------------------------------------------------------
    // TODO - write strCmpCnt()
    //---------------------------------------------------------
    
    //will count total num of differing char positions and includes extra chars if length differs
    
    //will create the length variables as ints
    int theLength1 = (int)strlen(str1);
    int length2 = (int)strlen(str2);
    //will create countWordsOfLength
    int counter = 0;

    //will look through mn and count how many difference
    for(int i=0; i<theLength1 && i<length2; i++)
    {
        //will check if str1 element is not str2 element
        if(str1[i] != str2[i])
        {
            counter++;
        }
    }

    //will add the difference in length to the counter
    if(theLength1>length2)
    {
        counter+=theLength1-length2;
    }
    //if anything else
    else
    {
        counter+=length2-theLength1;
    }

    //will return the counter variable
    return counter; //modify this line
}

int strCmpInd(char* str1, char* str2) {
    //---------------------------------------------------------
    // TODO - write strCmpInd()
    //---------------------------------------------------------

    //wil return index of first differing char, return -1 if identical, return length of shorter str if prefixed

    //will create the i variable
    int i=0;

    //will loop through the str variables and return the element inside 
    while(str1[i]!='\0' && str2[i]!='\0')
    {
        if(str1[i] != str2[i])
        {
            return i;
        }
        //will increment i to next index
        i++;
    }

    //will go through each elemenet in str1 and str2
    if(str1[i]=='\0' && str2[i]=='\0')
    {
        return -1;
    }

    //will return i 
    return i; //modify this line
}

