    - Returns true if word 
      (a) uses ONLY letters that are in the hive, and 
      (b) MUST use the required letter. 
    - Returns false otherwise
    */

    //will set initial to false as starting pointer
    bool hasReq = false;
    
    //will loop through the word of elements
    for(int i=0; word[i]; i++)
    {

        //will return false if the findLetter is -1
        if(findLetter(hive, word[i]) == -1)
        {
            return false;
        }

        //will return true if the elemnt is equal to hasLet
        if(word[i] == reqLet)
        {
            hasReq = true;
        }
    }
    //return the has eq
    return hasReq;
}

