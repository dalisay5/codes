    - Calculate the number of valid words, number of pangrams, number of perfect pangrams, 
          total possible score, and whether there is a bingo. Save those values in the corresponding
          variables, or update the printf statements below to dispay those values
    */

    //the variables
    int hiveLen = strlen(hive);
    //will compute the statistics while printing the solved words
    bool hiveUsed[12] = {false};
    numValidWords = 0;
    numPangrams = 0;
    numPerfectPangrams = 0;
    totScore = 0;

    //will go through each one of the solved word
    for(int i=0; i<solvedList->numWords; i++)
    {
        //will create word variable that is the element inside index i of the list
        char* word = solvedList->words[i];
        //will create variable for storing the length of word
        int wordLen = strlen(word);

        //will create booleans to be changed later
        bool isPangram = true;
        bool isPerfect = true;

        //will check each one of the hiver letters
        for(int h=0; h<hiveLen; h++)
        {
            int counter = 0;
            for(int j=0; j<wordLen; j++)
            {
                if(word[j] == hive[h])
                {
                    counter++;
                }
            }
            if(counter == 0)
            {
                isPangram = false;
            }
            if(counter != 1)
            {
                isPerfect = false;
            }
        }

        //will update the countUniqueLetters
        numValidWords++;
        if(isPangram)
        {
            numPangrams++;
        }
        if(isPerfect)
        {
            numPerfectPangrams++;
        }

        //will add the score, with example simple: word length
        totScore += wordLen;

        //will track the letters that is used for the bingo
        for(int h=0; h<hiveLen; h++)
        {
            if(word[0] == hive[h])
            {
                hiveUsed[h] = true;
            }
        }

        //will print the word with the astericks for pangrams
        if(isPerfect)
        {
            printf("  *** (%2d) %s\n", wordLen, word);
        }
        else if(isPangram)
        {
            printf("   * (%2d) %s\n", wordLen, word);
        }
        else
        {
            printf("      (%2d) %s\n", wordLen, word);
        }
    }
    //will check if the hive is a bingo where each letters starts a word
    isBingo = true;
    for(int h=0; h<hiveLen; h++)
    {
        if(!hiveUsed[h])
        {
            isBingo = false;
            break;
        }
    }
