/*Project Description:  OTHER FILES WERE INCLUDED IN PROJECT BUT ONLY MAIN IS PRESENT HERE
The purpose of this project is for building a totalistic cellular automation, which is 
basically a row of cell that will change over time depending on simple rules like for 
the sum of the states of it's neighboring cells. Each cell in this project has the value 
of 0, 1, or 2, and it's next state will depend on the sum of itself as well as its two 
neighbors. A rule number that is between 0 and 2186 will define how every possible sum
will map to a new value. The user will choose how many generations to evolve as well as 
the starting value to place in the middle cell in order for the program to show the world 
evolving. Finally, the program will totally show how active each cell was across all the generations. 
*/

//Totalistic Cellular Automaton

#include <stdio.h>
#include <stdbool.h>

const int WORLD_SIZE = 65;

typedef struct cell_struct{
    int localSum; // total sum of local cells, [left] + [me] + [right]: possible values are 0-6
    int status;   // this cell's current status: 0, 1, or 2
    int count;    // running accumulated count of this cell's active status for all generations
} cell;

// convert an integer rule (0-2186) to its base-3 representation, 
// stored in reverse order, as an array of 7 status values, i.e. valArray[7] 
//   ex: rule = 777  -> [0121001], since 777  = 1*3^1 + 2*3^2 + 1*3^3 + 1*3^6   
//   ex: rule = 177  -> [0210200], since 177  = 2*3^1 + 1*3^2 + 2*3^4
//   ex: rule = 2040 -> [0210122], since 2040 = 2*3^1 + 1*3^2 + 1*3^4 + 2*3^5 + 2*3^6
//return true if input rule is valid (0-2186)
//return false if input rule is invalid
bool setValArray(int valArray[7], int rule) {

        //TODO: Task 1 - write the setValArray() function
        // printf("hello world**************************************");
        if(rule<0 || rule > 2186)
        {
            return false;
        }

        for(int i=0; i<7; i++)
        {
            valArray[i] = rule % 3;
            rule = rule / 3;
        }

        return true;
}

// update the localSum subitem for each cell in the world array based on the
// current statuses for the nearby [left, me, right] cells
// note: world is periodic/cyclic, with front-to-back and back-to-front wrapping 
void setSums(cell world[WORLD_SIZE]) {

    //TODO: Task 4 - write the setSums() function
    for(int i=0; i<WORLD_SIZE; i++)
    {
        int left;
        int right;

        //for left neighbor
        if(i==0)
        {
            //for first cell, left neighbor is the last cell wrapped around
            left = world[WORLD_SIZE - 1].status;
        }
        else
        {
            left = world[i-1].status;
        }

        //for right neighbor
        if(i==(WORLD_SIZE-1))
        {
            //for last cell, right neighbor is the first cell wrapped around
            right = world[0].status;
        }
        else
        {
            right = world[i+1].status;
        }

        //calculates local sum(left + me right)
        world[i].localSum= left + world[i].status + right; 
    }


    return;
}

// Evolve the world to the next generation by updating each cell's status value 
// using its localSum subitem (assumed to be updated outside of this function), where
// ruleValArray[7] stores the status values for the 7 possible local sums, in reverse order, 
// e.g. if local sum = 4, the new status value can be found at index 4 of the ruleValArray[].
// This function must also update the count subitems for all cells in world[] 
// with the new generation status values.
// This function returns the total sum of all status values in world[] after the evolution step.
int evolveWorld(cell world[WORLD_SIZE], int ruleValArray[7]) {

    //TODO: Task 6 - write the evolveWorld() function
    int total = 0;

    //will compute and will update the new status using the localSum from the last generations. 
    for(int i=0; i<WORLD_SIZE; i++)
    {
        //sum of left, me, and right, localSum is computed before using evolveWorld function
        int sum = world[i].localSum;
        //will tell us the new status for the local sum
        int newStatus = ruleValArray[sum];

        //updates the status in place
        world[i].status = newStatus;
        //adds new status into the used count
        world[i].count += newStatus;
        //count the generation in total
        total+=newStatus;

    }

    

    /*updates the local sums for the next generation, 
    so that next call to evolveWorld uses correct local sums*/
    for(int i=0; i<WORLD_SIZE;i++)
    {
        //neighbor variables
        int leftNeighbor;
        int rightNeighbor;

        //checks for left neighbor if it exists
        if(i==0)
        {
            leftNeighbor = world[WORLD_SIZE-1].status;
        }
        else
        {
            leftNeighbor = world[i-1].status;
        }
        
        //checks for right neighbor if it exists
        if(i==WORLD_SIZE-1)
        {
            rightNeighbor = world[0].status;
        }
        else
        {
            rightNeighbor = world[i+1].status;
        }
        //localSum is equal to left+me+right
        world[i].localSum = leftNeighbor + world[i].status + rightNeighbor;
    }
    //will return the total
    return total;
}

//helper function for task 5, printing one generation of the world
void printInitializeWorld(cell world[])
{
    //sum of the statuses in the current generation
    int total=0;
    for(int i=0; i<WORLD_SIZE; i++)
    {
        if(world[i].status==0)
        {
            printf(" ");
        }
        else if(world[i].status==1)
        {
            printf("-");
            total+=1;
        }
        else if(world[i].status==2)
        {
            printf("+");
            total+=2;
        }
    }
    printf(" %d \n", total);
}

