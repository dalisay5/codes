using namespace std;

template <typename KeyT, typename ValT>
class HashMap {
 private:
  struct ChainNode {
    const KeyT key;
    ValT value;
    ChainNode* next;

    ChainNode(KeyT key, ValT value) : key(key), value(value), next(nullptr) {
    }

    ChainNode(KeyT key, ValT value, ChainNode* next)
        : key(key), value(value), next(next) {
    }
  };

  ChainNode** data;
  size_t sz;
  size_t capacity;

  // Utility members for begin/next
  ChainNode* curr;
  size_t curr_idx;

  //&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&
  // private helper functions below

  // will be for returning the hash size with type size_t for any number
  size_t hashFunction(const KeyT& key) const {
    return hash<KeyT>{}(key) % capacity;
  }

  // will be private function for resizing the hash,
  void resize() {
    // will set the old to capaicty and double it
    size_t old_capacity = capacity;
    capacity = capacity * 2;

    // will make the new bucket array
    ChainNode** newData = new ChainNode*[capacity];
    // will loop through the capacity
    for (size_t i = 0; i < capacity; i++) {
      newData[i] = nullptr;
    }

    // will move the old nodes into the new buckets
    for (size_t i = 0; i < old_capacity; i++) {
      // will set the current node
      ChainNode* currNode = data[i];
      // willl go as long as the current node valid
      while (currNode) {
        ChainNode* theNextNode = currNode->next;

        // will re-hash using the new capaicty
        size_t theNewIndex = hash<KeyT>{}(currNode->key) % capacity;

        // will insert at the front of the new data in index new index
        currNode->next = newData[theNewIndex];
        // will set the new index inside new data to current node
        newData[theNewIndex] = currNode;

        // will set the current node to the next one
        currNode = theNextNode;
      }
    }
    // will delete the data
    delete[] data;
    // will set the data to the new one
    data = newData;
  }

  //&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&

 public:
  // other public functions

  /**
   * Creates an empty `HashMap` with 10 buckets.
   */
  HashMap() {
    // TODO_STUDENT
    // will set the size and capacity
    sz = 0;
    capacity = 10;

    // will set the data and create a new one
    data = new ChainNode*[capacity];

    // will loop through the capacity
    for (size_t i = 0; i < capacity; i++) {
      // will set each to nullptr
      data[i] = nullptr;
    }
  }

  /**
   * Creates an empty `HashMap` with `capacity` buckets.
   */
  HashMap(size_t capacity) {
    // TODO_STUDENT
    // will set size to 0 and set capacity
    sz = 0;
    this->capacity = capacity;
    // will set new data to type ChainNode
    data = new ChainNode*[capacity];
    // will loop through the capacity
    for (size_t i = 0; i < capacity; i++) {
      // will set each element in data to null to avoid leak
      data[i] = nullptr;
    }
  }

  /**
   * Checks if the `HashMap` is empty. Runs in O(1).
   */
  bool empty() const {
    // TODO_STUDENT

    // will return the sz as 0
    return sz == 0;
  }

  /**
   * Returns the number of mappings in the `HashMap`. Runs in O(1).
   */
  size_t size() const {
    // TODO_STUDENT

    // will return the size
    return sz;
  }

  /**
   * Adds the mapping `{key -> value}` to the `HashMap`. If the key already
   * exists, does not update the mapping (like the C++ STL map).
   *
   * Uses the hash value of the key to determine the location in the
   * underlying hash table. Creates exactly one new node; resizes by doubling
   * when the load factor exceeds 1.5.
   *
   * On resize, doesn't create new nodes, but rearranges existing ones.
   *
   * Runs in O(L), where L is the length of the longest chain.
   */
  void insert(KeyT key, ValT value) {
    // TODO_STUDENT

    // will get the index as the hash
    size_t idx = hashFunction(key);

    // will set the node to the element at the index of data
    ChainNode* currNode = data[idx];
    // will be valid as current is valid
    while (currNode) {
      // will be for it already existing
      if (currNode->key == key) {
        return;
      }
      currNode = currNode->next;
    }
    // will insert at the front
    data[idx] = new ChainNode(key, value, data[idx]);
    sz++;

    // will check the load factor is it is greater than 1.5, than double
    if ((double)sz / capacity > 1.5) {
      resize();
    }
  }

  /**
   * Return a reference to the value stored for `key` in the map.
   *
   * If key is not present in the map, throw `out_of_range` exception.
   *
   * Runs in O(L), where L is the length of the longest chain.
   */
  ValT& at(const KeyT& key) const {
    // TODO_STUDENT

    // will make the the index using the hash function i created above
    size_t idx = hashFunction(key);
    // will set node to the data[index]
    ChainNode* currNode = data[idx];
    // will be condition if node is valid
    while (currNode) {
      // will return the value of node
      if (currNode->key == key) {
        return currNode->value;
      }
      // will set node to next
      currNode = currNode->next;
    }
    // will return false and out of range if key is not found
    throw out_of_range("key is not found");
  }

  /**
   * Returns `true` if the key is present in the map, and false otherwise.
   *
   * Runs in O(L), where L is the length of the longest chain.
   */
  bool contains(const KeyT& key) const {
    // will set the index using the hash function
    size_t idx = hashFunction(key);
    // will set the node
    ChainNode* currNode = data[idx];
    // will check if the key is equal to node key
    while (currNode) {
      if (currNode->key == key) {
        // will return true
        return true;
      }
      // will set the node to node->next
      currNode = currNode->next;
    }
    return false;
  }

  /**
   * Empties the `HashMap`, freeing all nodes. The bucket array may be left
   * alone.
   *
   * Runs in O(N+B), where N is the number of mappings and B is the number of
   * buckets.
   */
  void clear() {
    // TODO_STUDENT
    // will loop through capacity
    for (size_t i = 0; i < capacity; i++) {
      // will set the node
      ChainNode* currNode = data[i];
      // will set as long as current node is valid
      while (currNode) {
        // will next to node-Next
        ChainNode* next = currNode->next;
        // will delete the node
        delete currNode;
        // will set the current node to next
        currNode = next;
      }
      // will set the current element of data to null
      data[i] = nullptr;
    }
    // will size the size to 0
    sz = 0;
  }

  /**
   * Destructor, cleans up the `HashMap`.
   *
   * Runs in O(N+B), where N is the number of mappings and B is the number of
   * buckets.
   */
  ~HashMap() {
    // TODO_STUDENT
    // will use the clear function
    clear();
    // will delete the current data
    delete[] data;
  }

  /**
   * Removes the mapping for the given key from the `HashMap`, and returns the
   * value.
   *
   * Throws `out_of_range` if the key is not present in the map. Creates no new
   * nodes, and does not update the key or value of any existing nodes.
   *
   * Runs in O(L), where L is the length of the longest chain.
   */
  ValT erase(const KeyT& key) {
    // TODO_STUDENT
    // will create the index using the hash function
    size_t idx = hashFunction(key);
    // will set the curr node to the current index of data
    ChainNode* currNode = data[idx];
    // will set the previous node to null
    ChainNode* prevNode = nullptr;

    // will go as long as current node is valid
    while (currNode) {
      // will check if node is key of node
      if (currNode->key == key) {
        // will make sure previous node is valid too
        if (prevNode) {
          prevNode->next = currNode->next;
        } else {
          // will set the index of data to node next
          data[idx] = currNode->next;
        }
        // will create a variable to set the value of node
        ValT currValue = currNode->value;
        // will delete the currNode to avoid leaks
        delete currNode;
        // will decrement the size of the hash
        sz = sz - 1;
        // will return the the value
        return currValue;
      }
      // will set the previous to curr node and current node to next
      prevNode = currNode;
      currNode = currNode->next;
    }
    // will throw out of range error is key is not found
    throw out_of_range("key is not found");
  }

  /**
   * Copy constructor.
   *
   * Copies the mappings from the provided `HashMap`.
   *
   * Runs in O(N+B), where N is the number of mappings in `other`, and B is the
   * number of buckets.
   */
  HashMap(const HashMap& other) {
    // TODO_STUDENT
    // will set the size to 0 and capacity to capacity of other
    sz = 0;
    capacity = other.capacity;
    // will initialize the data in order to avoid the error
    data = new ChainNode*[capacity];
    // will loop through the capacity
    for (size_t i = 0; i < capacity; i++) {
      // will set the element i of data to null
      data[i] = nullptr;
    }
    // will loop through the capacity of other
    for (size_t i = 0; i < other.capacity; i++) {
      // will set node to element of element of other
      ChainNode* currNode = other.data[i];
      // will insert the node key of value
      while (currNode) {
        insert(currNode->key, currNode->value);
        // will set node to next
        currNode = currNode->next;
      }
    }
  }

  /**
   * Assignment operator; `operator=`.
   *
   * Clears this table, and copies the mappings from the provided `HashMap`.
   *
   * Runs in O((N1+B1) + (N2+B2)), where N1 and B1 are the number of mappings
   * and buckets in `this`, and N2 and B2 are the number of mappings and buckets
   * in `other`.
   */
  HashMap& operator=(const HashMap& other) {
    // TODO_STUDENT
    // will basically self assign itself
    if (this == &other) {
      // will retunr this
      return *this;
    }
    // will use the clear function and delete the data
    clear();
    delete[] data;
    // will set the capacity to capacity of other
    capacity = other.capacity;
    // will set the data and make a new one thats already set
    data = new ChainNode*[capacity];
    // will loop through the capaicty
    for (size_t i = 0; i < capacity; i++) {
      data[i] = nullptr;
    }
    // will loop through the capacity of other
    for (size_t i = 0; i < other.capacity; i++) {
      // will set the node
      ChainNode* currNode = other.data[i];
      // will use insert
      while (currNode) {
        insert(currNode->key, currNode->value);
        currNode = currNode->next;
      }
    }
    // will return this
    return *this;
  }

  // =====================

  /**
   *
   * Checks if the contents of `this` and `other` are equivalent.
   *
   * Two `HashMap` objects are equivalent if they contain the same
   * mappings from key to value. To be equivalent, the two `HashMap`
   * objects need not have the elements saved in the same order
   * inside of the buckets.
   *
   * Runs in worst-case O(B*L) time, where B is the maximum number
   * of buckets in either of the `HashMap` objects and L is the length
   * of the  largest chain on any of the buckets.
   *
   */
  bool operator==(const HashMap& other) const {
    // TODO_STUDENT
    // will remove the other error that i got
    // will make sure sz is not equal to size of other
    if (sz != other.sz) {
      // will return false
      return false;
    }
    // will loop through the capacity
    for (size_t i = 0; i < capacity; i++) {
      // will set the node
      ChainNode* currNode = data[i];
      // will go while current node is valid
      while (currNode) {
        // will make sure other contains the key of noe
        if (!other.contains(currNode->key)) {
          // will return false
          return false;
        }
        // will make sure key of node at other is not the value of node
        if (other.at(currNode->key) != currNode->value) {
          // will return false
          return false;
        }
        // will set the current node to next
        currNode = currNode->next;
      }
    }
    // wll return true if all other previous statements is false
    return true;
  }

  /**
   * Resets internal state for an iterative traversal.
   *
   * See `next` for usage details. Modifies nothing except for `curr` and
   * `curr_idx`.
   *
   * Runs in worst-case O(B), where B is the number of buckets.
   */
  void begin() {
    // TODO_STUDENT

    // will for starting at bucket 0
    curr_idx = 0;
    curr = nullptr;

    // will find the first bucket that is not empty
    while (curr_idx < capacity && data[curr_idx] == nullptr) {
      curr_idx = curr_idx + 1;
    }

    // will set the curr to the first node if there is an empty bucket
    if (curr_idx < capacity) {
      curr = data[curr_idx];
    }
  }

  /**
   * Uses the internal state to return the "next" key and value
   * by reference, and advances the internal state. Returns `true` if the
   * reference parameters were set, and `false` otherwise.
   *
   * Example usage:
   *
   * ```c++
   * HashMap<string, int> hm;
   * hm.begin();
   * string key;
   * int value;
   * while (hm.next(key, val)) {
   *   cout << key << ": " << val << endl;
   * }
   * ```
   *
   * Does not visit the mappings in any defined order.
   *
   * Modifies nothing except for `curr` and `curr_idx`.
   *
   * Runs in worst-case O(B) where B is the number of buckets.
   */
  bool next(KeyT& key, ValT& value) {
    // TODO_STUDENT
    // will be for no more items at all
    if (curr == nullptr) {
      return false;
    }

    // will give the user the current key or value
    key = curr->key;
    value = curr->value;

    // will move to the next node in the same chain
    if (curr->next != nullptr) {
      curr = curr->next;
      return true;
    }

    // will move to the nex bucket if previous case is false
    curr_idx = curr_idx + 1;

    // will scan to the next foward to find the next bucket that is empty
    while (curr_idx < capacity && data[curr_idx] == nullptr) {
      curr_idx = curr_idx + 1;
    }

    // will check for a valid bucket
    if (curr_idx < capacity) {
      curr = data[curr_idx];
    } else {
      // will be for no more data;
      curr = nullptr;
    }
    // will switch to returning to true
    return true;
  }

  // ===============================================

  /**
   * Returns a pointer to the underlying memory managed by the `HashMap`.
   * For autograder testing purposes only.
   */
  void* get_data() const {
    return this->data;
  }

  /**
   * Returns the capacity of the underlying memory managed by the `HashMap`. For
   * autograder testing purposes only.
   */
  size_t get_capacity() {
    return this->capacity;
  }
};

