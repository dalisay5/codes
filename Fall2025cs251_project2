// this function wwill "trim" words and return a lowercase/ etc value
string cleanToken(const string& token) {
  // TODO student

  // will check if the token/string is empty
  if (token.empty()) {
    return "";
  }

  // will be the variable string that we can change
  string finalResult = token;

  // will make a lowercase copy, will need ampersand to change c
  for (char& c : finalResult) {
    c = tolower(c);
  }

  // will cut out the punctuation from the front
  size_t start = 0;
  while (start < finalResult.size() && ispunct(finalResult[start])) {
    start++;
  }

  // will cut out the punctuation from the back
  size_t theEnd = finalResult.size();
  while (theEnd > start && ispunct(finalResult[theEnd - 1])) {
    theEnd--;
  }

  // will get a new shorter length from the starting index
  finalResult = finalResult.substr(start, theEnd - start);

  // will check if it contain at least one letter
  bool hasLetter = false;
  for (char c : finalResult) {
    if (isalpha(c)) {
      hasLetter = true;
      break;
    }
  }
  // if hasLetter variable is true, return nothing
  if (!hasLetter) {
    return "";
  }

  return finalResult;
}

// this function will get unique words seperated by spaces, from the text
set<string> gatherTokens(const string& text) {
  // TODO student

  // will create a set to avoid uniques
  set<string> wordSet;
  // will create a stringstream variable to treat the token like input
  istringstream textFromFile(text);
  // will be the new variable to be stored
  string inputText;

  // will split the whitespace
  while (textFromFile >> inputText) {
    // variable that will clean the input
    string cleanedWord = cleanToken(inputText);
    // will make sure that the set is unique
    if (!cleanedWord.empty()) {
      wordSet.insert(cleanedWord);
    }
  }

  return wordSet;
}

