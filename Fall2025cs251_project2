// This function will return indices that has the key tokens and song values
int buildIndices(const string& filename,
                 map<string, set<string>>& inverted_index,
                 map<string, string>& artist_index) {
  // TODO student

  // will get the file and check if cannot open
  ifstream infile(filename);
  if (!infile.is_open()) {
    // file not found, will fail the program
    return 0;
  }

  // will create strings for input
  string title;
  string artist;
  string lyrics;

  // will create a counter
  int songCounter = 0;

  // will read the input
  while (getline(infile, title) && getline(infile, artist) &&
         getline(infile, lyrics)) {
    // will add the song to artist map
    artist_index[title] = artist;

    // will seperate the tokens from the lyrics
    set<string> tokens = gatherTokens(lyrics);

    // will seperate the title as well
    set<string> titleTokens = gatherTokens(title);

    // will combine the title tokens into the same set
    tokens.insert(titleTokens.begin(), titleTokens.end());

    // will update the inverted index
    for (const string& token : tokens) {
      string clean = cleanToken(token);
      if (!clean.empty()) {
        // will use clean not token
        inverted_index[clean].insert(title);
      }
    }

    // will increment the song counter
    songCounter++;
  }

  return songCounter;
}

// helper function for findQueryMatches(), gets matches for a token from index
set<string> getMatches(const map<string, set<string>>& index,
                       const string& token) {
  // will first deal with lowercase,punctuations, etc
  string cleanWord = cleanToken(token);
  // will create a set to return the unique words
  set<string> result;

  // will check if the word(token) exists in the index
  if (index.count(cleanWord) > 0) {
    // if the word does exist in the index, it will copy the set over
    result = index.at(cleanWord);
  }

  return result;
}
// function will find the titles of songs that match search query
set<string> findQueryMatches(const map<string, set<string>>& index,
                             const string& sentence) {
  // TODO student

  // will create the file variable for input
  stringstream inputFile(sentence);
  // will create the original word variable to change
  string word;
  // will create the set result which is the current result
  set<string> result;
  // will keep track of the first query term and will be changed
  bool firstWord = true;

  // will go through each word in the query
  while (inputFile >> word) {
    // will create the modifier which will start as null character
    char modifier = '\0';
    // will create a new string to store word
    string token = word;

    // will check for + or - modifier
    if (word[0] == '+' || word[0] == '-') {
      modifier = word[0];
      // will remove the + or - in the word
      token = word.substr(1);
    }

    // will get the set of matches for this token
    set<string> matches = getMatches(index, token);
    // will combine the sets which is based on the modifier
    if (firstWord) {
      // First word: start the result set
      result = matches;
      firstWord = false;
    } else {
      // project manual said that I can use function: diff, inters, and union
      set<string> temp;
      if (modifier == '+') {
        // will be for Intersection which has '+'
        set_intersection(result.begin(), result.end(), matches.begin(),
                         matches.end(), inserter(temp, temp.begin()));
        result = temp;
      } else if (modifier == '-') {
        // will be for Difference which has '-'
        set_difference(result.begin(), result.end(), matches.begin(),
                       matches.end(), inserter(temp, temp.begin()));
        result = temp;
      } else {
        // will be for union, which has no modifier
        set_union(result.begin(), result.end(), matches.begin(), matches.end(),
                  inserter(temp, temp.begin()));
        result = temp;
      }
    }
  }

  return result;
}

