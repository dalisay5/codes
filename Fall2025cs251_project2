void searchEngine(const string& filename) {
  // will create the maps for inverted index and the artist index
  map<string, set<string>> inverted_index;
  map<string, string> artist_index;

  // will check if the file exists first
  ifstream infile(filename);
  if (!infile.is_open()) {
    cout << "Invalid filename." << endl;
    cout << "Stand by while building indices..." << endl;
    cout << "Indexed 0 songs containing 0 unique terms and 0 artists." << endl;
    cout << "Enter query sentence (press enter to quit): Found 0 matching songs"
         << endl;
    cout << "Enter query sentence (press enter to quit): Thank you for "
            "searching our Lyrics DB!"
         << endl;
    return;
  }
  infile.close();

  cout << "Stand by while building indices..." << endl;

  // will build indices
  int numSongs = buildIndices(filename, inverted_index, artist_index);

  // will Count number of unique words
  int numWords = inverted_index.size();

  // will Count number of unique artists by looping through artist_index
  set<string> uniqueArtists;
  for (const auto& pair : artist_index) {
    uniqueArtists.insert(pair.second);
  }
  // will store the number of unique artists
  int numArtists = uniqueArtists.size();

  cout << "Indexed " << numSongs << " songs containing " << numWords
       << " unique terms and " << numArtists << " artists." << endl;

  // will run until the if statements reach break
  while (true) {
    cout << "Enter query sentence (press enter to quit): ";
    string query;
    // will ask for input
    if (!getline(cin, query)) {
      break;
    }
    if (query.empty()) {
      break;
    }

    // will create a set of strings
    set<string> results = findQueryMatches(inverted_index, query);

    cout << "Found " << results.size() << " matching songs" << endl;

    // will Print songs in alphabetical order
    vector<string> sortedResults(results.begin(), results.end());
    sort(sortedResults.begin(), sortedResults.end());

    // will loop through the sortedResults and print them out
    for (const auto& song : sortedResults) {
      cout << song << " by " << artist_index[song] << endl;
    }
  }

  cout << "Thank you for searching our Lyrics DB!" << endl;
}
